# ── Database ────────────────────────────────────────────────────────────────────
# Supabase PostgreSQL connection string (asyncpg driver).
# Get this from your Supabase project dashboard → Settings → Database → Connection string.
# Replace username, password, host, and database with your actual values.
DATABASE_URL=postgresql+asyncpg://postgres:your_password@db.xxxxx.supabase.co:5432/postgres?sslmode=require

# Optional: sync URL for Alembic migrations / admin tools (psycopg2 driver).
# Usually the same as DATABASE_URL but without the +asyncpg suffix.
DATABASE_URL_SYNC=postgresql://postgres:your_password@db.xxxxx.supabase.co:5432/postgres?sslmode=require

# ── CORS ────────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS.
# For production, include your frontend domain(s).
# For local development, the fallback covers localhost:3000, :5173, and 127.0.0.1:5173.
CORS_ORIGINS=https://satom-global-venture.vercel.app,https://your-custom-domain.com

# ── JWT / Auth ──────────────────────────────────────────────────────────────────
# Generate a strong random secret key (e.g., via `openssl rand -hex 32`).
SECRET_KEY=your-secret-key-here-change-in-production

# Token expiration time in minutes (default: 480 = 8 hours).
ACCESS_TOKEN_EXPIRE_MINUTES=480